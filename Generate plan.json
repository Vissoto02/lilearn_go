    {
      "parameters": {
        "text": "={{ $json }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a study planner AI. Generate an optimal study schedule based on the provided data. Follow these rules strictly:\n\n1. Use ONLY the provided free_time_slots - do not schedule outside these times\n2. Do NOT overlap with existing_events\n3. Prioritize weaker subjects (lower performance scores) with more study time\n4. Respect all deadlines - schedule more intensive study sessions before deadline dates\n5. Follow the user settings for plan duration, target study hours, study intensity, and preferred study times\n6. Each study session should have a clear reason explaining why it was scheduled\n\nReturn ONLY valid JSON matching the exact structure specified in the output schema."
        }
      },
      "id": "5ce0aeac-5fc6-45d3-a935-3e656b0b9835",
      "name": "Generate Study Plan",
