    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"study_plan\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"date\": {\n            \"type\": \"string\",\n            \"description\": \"Date in YYYY-MM-DD format\"\n          },\n          \"start_time\": {\n            \"type\": \"string\",\n            \"description\": \"Start time in HH:MM format\"\n          },\n          \"end_time\": {\n            \"type\": \"string\",\n            \"description\": \"End time in HH:MM format\"\n          },\n          \"subject\": {\n            \"type\": \"string\",\n            \"description\": \"Subject name\"\n          },\n          \"topic\": {\n            \"type\": [\"string\", \"null\"],\n            \"description\": \"Specific topic or null\"\n          },\n          \"reason\": {\n            \"type\": \"string\",\n            \"description\": \"Explanation for why this session was scheduled\"\n          }\n        },\n        \"required\": [\"date\", \"start_time\", \"end_time\", \"subject\", \"topic\", \"reason\"]\n      }\n    }\n  },\n  \"required\": [\"study_plan\"]\n}",
        "autoFix": true
      },
